use crate::error::Result;
use rusqlite::Connection;
use std::path::{Path, PathBuf};

fn get_db_path(config_path: &Path) -> PathBuf {
    let mut p = config_path.to_path_buf();
    p.set_extension("db");
    p
}
pub fn load_persistent_ids(config_path: &Path) -> Result<Vec<String>> {
    let db_path = get_db_path(config_path);
    let conn = Connection::open(&db_path)?;
    conn.execute(
        "CREATE TABLE IF NOT EXISTS persistent_ids (
            id TEXT PRIMARY KEY,
            added_at DATETIME DEFAULT CURRENT_TIMESTAMP
        )",
        [],
    )?;
    let mut stmt = conn.prepare("SELECT id FROM persistent_ids ORDER BY added_at DESC LIMIT 100")?;
    let ids_iter = stmt.query_map([], |row| row.get(0))?;
    let mut ids = Vec::new();
    for id in ids_iter {
        ids.push(id?);
    }
    ids.reverse();   
    Ok(ids)
}
pub fn save_persistent_id(config_path: &Path, id: &str) -> Result<()> {
    let db_path = get_db_path(config_path);
    let conn = Connection::open(&db_path)?;    
    conn.execute(
        "CREATE TABLE IF NOT EXISTS persistent_ids (
            id TEXT PRIMARY KEY,
            added_at DATETIME DEFAULT CURRENT_TIMESTAMP
        )",
        [],
    )?;
    conn.execute(
        "INSERT OR IGNORE INTO persistent_ids (id) VALUES (?1)",
        [id],
    )?;    
    Ok(())
}
